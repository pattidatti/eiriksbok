            "type": "header",
            "text": "Synd og tilgivelse"
        },
        {
            "type": "text",
            "content": "Kristendommen lærer at mennesket synder (gjør feil) og kommer bort fra Gud. Men Gud tilgir synd på grunn av Jesu død på korset."
        },
        {
            "type": "header",
            "text": "Nåde"
        },
        {
            "type": "text",
            "content": "Frelse er en gave fra Gud, ikke noe man kan gjøre seg fortjent til. Dette kalles nåde. Man blir frelst ved å tro på Jesus."
        },
        {
            "type": "header",
            "text": "Oppstandelse og evig liv"
        },
        {
            "type": "text",
            "content": "Kristne tror at Jesus sto opp fra de døde, og at de som tror på ham, skal få evig liv etter døden."
        }
    ],
    "concepts": [
        {
            "id": "nade",
            "term": "Nåde",
            "definition": "Guds ufortjente kjærlighet og tilgivelse."
        },
        {
            "id": "frelse",
            "term": "Frelse",
            "definition": "Å bli reddet fra synd og død til evig liv."
        },
        {
            "id": "synd",
            "term": "Synd",
            "definition": "Handlinger eller tanker som skiller mennesket fra Gud."
        }
    ],
