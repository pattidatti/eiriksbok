    "content": [
        {
            "type": "header",
            "text": "Mange guder, én kraft"
        },
        {
            "type": "text",
            "content": "Hinduismen har millioner av guder, men mange hinduer mener at alle disse bare er ulike former av den ene, upersonlige verdenssjelen: Brahman."
        },
        {
            "type": "header",
            "text": "Trimurti"
        },
        {
            "type": "text",
            "content": "Tre guder er spesielt viktige: Brahma (skaperen), Vishnu (opprettholderen) og Shiva (ødeleggeren). De representerer livets syklus."
        },
        {
            "type": "header",
            "text": "Avatarer"
        },
        {
            "type": "text",
            "content": "Guden Vishnu stiger av og til ned på jorden i en kropp for å redde verden. Disse kalles avatarer. Krishna og Rama er kjente avatarer."
        }
    ],
    "concepts": [
        {
            "id": "brahman",
            "term": "Brahman",
            "definition": "Verdenssjelen. Den guddommelige kraften som finnes i alt."
        },
        {
            "id": "atman",
            "term": "Atman",
            "definition": "Menneskets sjel, som er en del av Brahman."
        },
        {
            "id": "avatar",
            "term": "Avatar",
            "definition": "En gud som stiger ned på jorden i en kropp."
        }
    ],
    "quiz": [
