{
    "rules": {
        "analytics": {
            "views": {
                "$id": {
                    ".read": true,
                    ".write": true
                }
            },
            "active_users": {
                "$id": {
                    ".read": true,
                    ".write": true
                }
            },
            "unique_users": {
                "$id": {
                    ".read": true,
                    ".write": "data.exists() || !data.exists()"
                }
            }
        },
        "feedback": {
            "$feedbackId": {
                ".write": "!data.exists() && newData.exists()",
                ".validate": "newData.hasChildren(['message', 'timestamp']) && newData.child('message').isString() && newData.child('message').val().length < 5000"
            }
        },
        "rooms": {
            ".read": true,
            ".write": true
        },
        "quiz-data": {
            ".read": true,
            ".write": true
        },
        "compositions": {
            ".read": true,
            ".write": true
        },
        "presence": {
            ".read": true,
            ".write": true
        },
        ".read": false,
        ".write": false
    }
}