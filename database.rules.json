{
    "rules": {
        "simulation_accounts": {
            "$uid": {
                ".read": "$uid === auth.uid",
                ".write": "$uid === auth.uid"
            }
        },
        "simulation_reserved_names": {
            ".read": "auth != null",
            "$name": {
                ".write": "auth != null && (!data.exists() || data.val() === auth.uid) && newData.val() === auth.uid"
            }
        },
        "simulation_rooms": {
            ".read": "auth != null",
            ".write": "auth != null",
            "$pin": {
                "players": {
                    "$playerId": {
                        "resources": {
                            "$resourceId": {
                                ".validate": "newData.isNumber() && newData.val() >= 0"
                            }
                        },
                        "status": {
                            "stamina": {
                                ".validate": "newData.isNumber() && newData.val() <= 100"
                            }
                        }
                    }
                }
            }
        },
        "simulation_server_metadata": {
            ".read": "auth != null",
            ".write": "auth != null"
        }
    }
}