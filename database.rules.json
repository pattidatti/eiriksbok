{
    "rules": {
        "feedback": {
            "$feedbackId": {
                ".write": "!data.exists() && newData.exists()",
                ".validate": "newData.hasChildren(['message', 'timestamp']) && newData.child('message').isString() && newData.child('message').val().length < 5000"
            }
        },
        "rooms": {
            ".read": true,
            ".write": true
        },
        "quiz-data": {
            ".read": true,
            ".write": true
        }
    }
}